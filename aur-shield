#!/usr/bin/env python3
import sys
import os
import re
import json
import urllib.request
import subprocess
from datetime import datetime

BASE_DIR = os.path.expanduser("~/.config/aur-shield")
SIG_FILE = os.path.join(BASE_DIR, "signatures.txt")
BACKUP_FILE = os.path.join(BASE_DIR, "signatures.bak")
LOG_FILE = os.path.join(os.path.expanduser("~/.cache"), "aur-shield.log")
CACHE_DIR = "/var/cache/pacman/pkg"

DEFAULT_SIGNATURES = [
    r'("[a-z]")|([a-z]""[a-z])',
    r'npm.*install|bun.*install|atomic-lock-file|axios|got',
    r'curl.*|wget.*|fetch.*|/dev/tcp',
    r'base64\s+-d|eval\s+|sh\s+-c',
    r'bashrc|zshrc|fishrc|profile',
    r'\.config/(discord|Lightcord|WebCord|Viber)/',
    r'\.ssh/id_|Local\s+Storage',
    r'[^\x00-\x7F]{100,}',
    r'\.config/(google-chrome|chromium|BraveSoftware|microsoft-edge)/',
    r'nc\s+-e|netcat\s+|socat\s+|tftp\s+|sftp\s+'
]

C_GREEN = "\033[92m"
C_RED = "\033[91m"
C_YELLOW = "\033[93m"
C_BLUE = "\033[94m"
C_CYAN = "\033[96m"
C_BOLD = "\033[1m"
C_END = "\033[0m"

def init_env():
    os.makedirs(BASE_DIR, exist_ok=True)
    if not os.path.exists(SIG_FILE):
        with open(SIG_FILE, "w") as f:
            f.write("\n".join(DEFAULT_SIGNATURES) + "\n")

def log_alert(msg):
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    with open(LOG_FILE, "a") as f:
        f.write(f"{timestamp} {msg}\n")

def run_check():
    print(f"{C_BOLD}{C_YELLOW}[+] AUR-SHIELD: Preventive archive control...{C_END}")
    
    if not os.path.exists(SIG_FILE):
        init_env()

    with open(SIG_FILE, "r") as f:
        rules = [line.strip() for line in f if line.strip() and not line.startswith("#")]

    suspicious_count = 0

    for line in sys.stdin:
        pkg_name = line.split()[0] if line.split() else ""
        if not pkg_name:
            continue

        try:
            files = os.listdir(CACHE_DIR)
            pkg_regex = re.compile(rf"^{re.escape(pkg_name)}-\d+.*\.pkg\.tar\.zst$")
            pkg_files = sorted([f for f in files if pkg_regex.match(f)], key=lambda x: os.path.getmtime(os.path.join(CACHE_DIR, x)), reverse=True)
        except Exception:
            continue

        if not pkg_files:
            continue

        pkg_file_path = os.path.join(CACHE_DIR, pkg_files[0])
        meta_content = ""

        try:
            meta_content = subprocess.check_output(
                ["tar", "--zstd", "-xf", pkg_file_path, ".INSTALL", "-O"],
                stderr=subprocess.DEVNULL
            ).decode('utf-8', errors='ignore')
        except Exception:
            try:
                raw_info = subprocess.check_output(
                    ["tar", "--zstd", "-xf", pkg_file_path, ".PKGINFO", "-O"],
                    stderr=subprocess.DEVNULL
                ).decode('utf-8', errors='ignore')
                meta_content = "\n".join([l for l in raw_info.split('\n') if not re.match(r'^(depend|makedeped|optdepend|packager|size|url|license|replaces|conflict|provides) =', l)])
            except Exception:
                continue

        if not meta_content.strip():
            continue

        for rule in rules:
            try:
                match = re.search(rule, meta_content, re.IGNORECASE)
                if match:
                    suspicious_count += 1
                    line_match = [l.strip() for l in meta_content.split('\n') if re.search(rule, l, re.IGNORECASE)]
                    found_line = line_match[0] if line_match else ""

                    alert_msg = f"[ALERT] Package: {pkg_name} | Signature: {rule} | Line: {found_line}"
                    log_alert(alert_msg)

                    print(f"{C_RED}[!!!] CRITICAL THREAT DETECTED BEFORE INSTALLATION!{C_END}")
                    print(f"    Package:   {C_BOLD}{pkg_name}{C_END}")
                    print(f"    Archive:   {pkg_files[0]}")
                    print(f"    Signature: {rule}")
                    print(f"    Match:     {C_YELLOW}{found_line[:100]}{C_END}")
                    print("-" * 40)
                    break
            except Exception:
                continue

    if suspicious_count == 0:
        print(f"{C_GREEN}[+] Preventive check successful. Archives are clean. Installation allowed.{C_END}")
        sys.exit(0)
    else:
        print(f"{C_BOLD}{C_RED}[!] WARNING! Suspicious code found! Check logs in {LOG_FILE}{C_END}")
        sys.exit(1)

def run_update():
    print(f"{C_BOLD}{C_BLUE}[+] AUR-SHIELD: Syncing signatures via GitHub API...{C_END}")
    init_env()
    
    if os.path.exists(SIG_FILE):
        import shutil
        shutil.copy(SIG_FILE, BACKUP_FILE)
        print(f"{C_GREEN}[+] Created backup of current signatures.{C_END}")

    with open(SIG_FILE, "r") as f:
        local_rules = [line.strip() for line in f if line.strip()]

    url = "https://api.github.com/search/repositories?q=aur+malware+OR+ioc&sort=updated"
    req = urllib.request.Request(url, headers={'User-Agent': 'AUR-Shield-Client'})
    
    try:
        with urllib.request.urlopen(req, timeout=15) as response:
            data = json.loads(response.read().decode())
            added_count = 0
            # ВИПРАВЛЕНО: прибрали "curl\\\\s+-" зі списку ключових слів
            keywords = ["base64\\\\s+-d", "eval\\s+", "atomic-lock-file", "axios", "got"]
            
            for item in data.get("items", []):
                desc = item.get("description") or ""
                for kw in keywords:
                    if re.search(kw, desc, re.IGNORECASE):
                        clean_rule = kw.replace("\\\\", "\\")
                        if clean_rule not in local_rules:
                            local_rules.append(clean_rule)
                            print(f"{C_CYAN}    [New IoC from GitHub]: {clean_rule}{C_END}")
                            added_count += 1

            if added_count > 0:
                with open(SIG_FILE, "w") as f:
                    f.write("\n".join(local_rules) + "\n")
                print(f"{C_BOLD}{C_GREEN}[+] Sync complete! Added new signatures: {added_count}{C_END}")
            else:
                print(f"{C_YELLOW}[*] No new signatures found on GitHub. Database is up to date.{C_END}")

    except Exception as e:
        print(f"{C_RED}[!] GitHub API request failed: {e}{C_END}")

def print_status():
    print(f"{C_BOLD}{C_CYAN}=== AUR-SHIELD SYSTEM STATUS ==={C_END}")
    init_env()
    with open(SIG_FILE, "r") as f:
        sig_count = len([line for line in f if line.strip() and not line.startswith("#")])
    
    print(f"Signature DB:  {C_GREEN}{SIG_FILE}{C_END} ({sig_count} rules)")
    print(f"Backup File:   {BACKUP_FILE if os.path.exists(BACKUP_FILE) else 'None'}")
    print(f"Log Journal:   {LOG_FILE if os.path.exists(LOG_FILE) else 'Empty'}")
    print(f"Pacman Hook:   {'/etc/pacman.d/hooks/aur-hunter.hook' if os.path.exists('/etc/pacman.d/hooks/aur-hunter.hook') else 'NOT INSTALLED'}")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: aur-shield [--check | --update | --status]")
        sys.exit(1)

    arg = sys.argv[1]
    if arg == "--check":
        run_check()
    elif arg == "--update":
        run_update()
    elif arg == "--status":
        print_status()
    else:
        print(f"Unknown argument: {arg}")
        sys.exit(1)
